# Public
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Database — Neon / Supabase / local Postgres (required for Prisma)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public"

# Clerk (https://dashboard.clerk.com)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Vercel Blob — resume file storage (https://vercel.com/docs/storage/vercel-blob)
BLOB_READ_WRITE_TOKEN=

# AI — resume parsing & later pipelines (optional model override)
OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
